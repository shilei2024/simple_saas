# ──────────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────
# Creem.io Payment
# ──────────────────────────────────────────────
CREEM_WEBHOOK_SECRET=whsec_xxx
CREEM_API_KEY=creem_live_xxx
CREEM_API_URL=https://api.creem.io/v1

# ──────────────────────────────────────────────
# Site URLs
# ──────────────────────────────────────────────
BASE_URL=https://mindfulpenpal.com
CREEM_SUCCESS_URL=https://mindfulpenpal.com/dashboard

# ──────────────────────────────────────────────
# Gmail API (reads emails forwarded by ImprovMX)
# ──────────────────────────────────────────────
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token

# ──────────────────────────────────────────────
# Brevo SMTP (sends replies as penpal@mindfulpenpal.com)
# Get key at: https://app.brevo.com/settings/keys/smtp
# ──────────────────────────────────────────────
BREVO_API_KEY=xkeysib-xxx

# ──────────────────────────────────────────────
# AI Model
# ──────────────────────────────────────────────
AI_API_KEY=your-ai-api-key
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# ──────────────────────────────────────────────
# Cron Job
# ──────────────────────────────────────────────
CRON_SECRET=your-strong-random-secret

# ──────────────────────────────────────────────
# Optional: HTTP Proxy (for regions where Google APIs are blocked)
# ──────────────────────────────────────────────
# HTTPS_PROXY=http://127.0.0.1:7890
